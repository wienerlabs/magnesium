# Phase 1 unifies the orchestrator and workers on metered API billing.
# This key is required for both. Workers run claude -p with --bare, which forces
# ANTHROPIC_API_KEY auth and never reads subscription OAuth or the keychain.
ANTHROPIC_API_KEY=

# Optional operational overrides (defaults live in src/config/defaults.ts).
# MAGNESIUM_BUDGET_USD=5
# MAGNESIUM_PER_WORKER_BUDGET_USD=1
# MAGNESIUM_CONCURRENCY=3
# MAGNESIUM_WORKER_IMAGE=magnesium/worker:dev
# MAGNESIUM_CONTAINER_RUNTIME=orbstack
# MAGNESIUM_LOG_LEVEL=info
# MAGNESIUM_LOG_PRETTY=1
