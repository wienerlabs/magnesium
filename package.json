  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
