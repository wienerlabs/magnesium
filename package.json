{
  "name": "magnesium",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted multi-agent orchestration harness around Claude Opus 4.8",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "magnesium": "./dist/magnesium.js"
  },
  "files": [
